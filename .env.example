# AI School — environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase project.
# Dashboard → Project Settings → API (or Data API / API Keys).

# Your project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The publishable "anon" key (safe to expose to the browser; RLS protects data).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
